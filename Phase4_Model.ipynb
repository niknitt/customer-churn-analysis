# pip install xgboost shap

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier
from xgboost import XGBClassifier
from sklearn.metrics import (roc_auc_score, classification_report,
                             confusion_matrix, ConfusionMatrixDisplay,
                             roc_curve)
from imblearn.over_sampling import SMOTE
import shap
import warnings
warnings.filterwarnings('ignore')
X_train = pd.read_csv('X_train.csv')
X_test  = pd.read_csv('X_test.csv')
y_train = pd.read_csv('y_train.csv').squeeze()
y_test  = pd.read_csv('y_test.csv').squeeze()

print('Train:', X_train.shape)
print('Test :', X_test.shape)
print('Churn distribution in train:\n', y_train.value_counts())
# EDA me dekha tha 73/27 split hai
# SMOTE minority class ke synthetic samples banata hai

smote = SMOTE(random_state=42)
X_train_sm, y_train_sm = smote.fit_resample(X_train, y_train)

print('Before SMOTE:', y_train.value_counts().to_dict())
print('After SMOTE :', y_train_sm.value_counts().to_dict())
# After SMOTE dono classes equal ho jaati hain
lr = LogisticRegression(random_state=42, max_iter=1000)
lr.fit(X_train_sm, y_train_sm)

lr_pred  = lr.predict(X_test)
lr_proba = lr.predict_proba(X_test)[:, 1]

print('=== Logistic Regression ===')
print(f'ROC-AUC : {roc_auc_score(y_test, lr_proba):.4f}')
print(classification_report(y_test, lr_pred))
rf = RandomForestClassifier(n_estimators=100, random_state=42)
rf.fit(X_train_sm, y_train_sm)

rf_pred  = rf.predict(X_test)
rf_proba = rf.predict_proba(X_test)[:, 1]

print('=== Random Forest ===')
print(f'ROC-AUC : {roc_auc_score(y_test, rf_proba):.4f}')
print(classification_report(y_test, rf_pred))
xgb = XGBClassifier(n_estimators=100, random_state=42,
                    eval_metric='logloss', use_label_encoder=False)
xgb.fit(X_train_sm, y_train_sm)

xgb_pred  = xgb.predict(X_test)
xgb_proba = xgb.predict_proba(X_test)[:, 1]

print('=== XGBoost ===')
print(f'ROC-AUC : {roc_auc_score(y_test, xgb_proba):.4f}')
print(classification_report(y_test, xgb_pred))
models = {
    'Logistic Regression' : (lr_pred,  lr_proba),
    'Random Forest'       : (rf_pred,  rf_proba),
    'XGBoost'             : (xgb_pred, xgb_proba)
}

print(f'{"Model":<22} {"ROC-AUC":>8} {"F1":>8} {"Recall":>8}')
print('-' * 50)
for name, (pred, proba) in models.items():
    from sklearn.metrics import f1_score, recall_score
    auc = roc_auc_score(y_test, proba)
    f1  = f1_score(y_test, pred)
    rec = recall_score(y_test, pred)
    print(f'{name:<22} {auc:>8.4f} {f1:>8.4f} {rec:>8.4f}')
cm = confusion_matrix(y_test, xgb_pred)
disp = ConfusionMatrixDisplay(cm, display_labels=['No Churn', 'Churned'])
disp.plot()
plt.title('XGBoost Confusion Matrix')
plt.show()

# Confusion matrix padna
tn, fp, fn, tp = cm.ravel()
print(f'True Negatives  (correctly said No Churn) : {tn}')
print(f'False Positives (wrongly said Churn)       : {fp}')
print(f'False Negatives (missed actual Churn)      : {fn}')
print(f'True Positives  (correctly said Churn)     : {tp}')
plt.figure(figsize=(8, 6))
for name, (pred, proba) in models.items():
    fpr, tpr, _ = roc_curve(y_test, proba)
    auc = roc_auc_score(y_test, proba)
    plt.plot(fpr, tpr, label=f'{name} (AUC={auc:.3f})')

plt.plot([0, 1], [0, 1], 'k--', label='Random classifier')
plt.title('ROC Curve Comparison')
plt.xlabel('False Positive Rate')
plt.ylabel('True Positive Rate')
plt.legend()
plt.show()
import pickle

with open('xgb_model.pkl', 'wb') as f:
    pickle.dump(xgb, f)

print('Model saved as xgb_model.pkl')
print('Phase 4 complete. Ready for Phase 5: Retention Analysis')
