import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans
from sklearn.metrics import silhouette_score
from sklearn.decomposition import PCA

X_train = pd.read_csv('X_train.csv')
X_test  = pd.read_csv('X_test.csv')
y_train = pd.read_csv('y_train.csv').squeeze()
y_test  = pd.read_csv('y_test.csv').squeeze()

# Full data for clustering
X = pd.concat([X_train, X_test], axis=0).reset_index(drop=True)
y = pd.concat([y_train, y_test], axis=0).reset_index(drop=True)

print(X.shape)
inertias = []
K_range = range(2, 11)

for k in K_range:
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    km.fit(X)
    inertias.append(km.inertia_)

plt.figure(figsize=(8, 4))
plt.plot(K_range, inertias, marker='o')
plt.title('Elbow Method')
plt.xlabel('Number of clusters (K)')
plt.ylabel('Inertia')
plt.xticks(K_range)
plt.show()
sil_scores = []

for k in K_range:
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    labels = km.fit_predict(X)
    score = silhouette_score(X, labels)
    sil_scores.append(score)
    print(f'K={k}  Silhouette Score: {score:.4f}')

plt.figure(figsize=(8, 4))
plt.plot(K_range, sil_scores, marker='o', color='green')
plt.title('Silhouette Score')
plt.xlabel('Number of clusters (K)')
plt.ylabel('Score')
plt.xticks(K_range)
plt.show()

print('Best K:', K_range[sil_scores.index(max(sil_scores))])
# Elbow + Silhouette dekh ke K choose karo (usually 3 ya 4)
K = 3

km = KMeans(n_clusters=K, random_state=42, n_init=10)
clusters = km.fit_predict(X)

# Cluster labels original dataframe me add karo
df_cluster = pd.read_csv('telco_clean.csv')
df_cluster['Cluster'] = clusters

print(df_cluster['Cluster'].value_counts())
# Har cluster ka average dekho
profile = df_cluster.groupby('Cluster').agg({
    'tenure'         : 'mean',
    'MonthlyCharges' : 'mean',
    'TotalCharges'   : 'mean',
    'Churn'          : lambda x: (x == 'Yes').mean() * 100
}).round(2)

profile.columns = ['Avg Tenure', 'Avg Monthly', 'Avg Total', 'Churn Rate %']
print(profile)

churn_by_cluster = df_cluster.groupby('Cluster')['Churn'].apply(
    lambda x: (x == 'Yes').mean() * 100
)
# 20+ columns hain, 2D me dikhane ke liye PCA use karo
pca = PCA(n_components=2, random_state=42)
X_pca = pca.fit_transform(X)

plt.figure(figsize=(9, 6))
for cluster in range(K):
    mask = clusters == cluster
    plt.scatter(X_pca[mask, 0], X_pca[mask, 1],
                alpha=0.3, s=10, label=f'Cluster {cluster}')
plt.title('Customer Segments (PCA 2D View)')
plt.xlabel('PCA Component 1')
plt.ylabel('PCA Component 2')
plt.legend(markerscale=4)
plt.show()
plt.figure(figsize=(7, 4))
plt.bar(churn_by_cluster.index, churn_by_cluster.values, edgecolor='white')
plt.title('Churn Rate by Cluster')
plt.xlabel('Cluster')
plt.ylabel('Churn Rate (%)')
for i, val in enumerate(churn_by_cluster.values):
    plt.text(i, val + 0.5, f'{val:.1f}%', ha='center', fontweight='bold')
plt.show()
df_cluster.to_csv('telco_clustered.csv', index=False)
print('Saved telco_clustered.csv')
print('Phase 3 complete. Ready for Phase 4: Churn Prediction Model')
