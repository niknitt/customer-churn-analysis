Add-on Services vs Churn
python
addon_services = ['OnlineSecurity', 'OnlineBackup', 'TechSupport',
                  'DeviceProtection', 'StreamingTV', 'StreamingMovies']

fig, axes = plt.subplots(2, 3, figsize=(15, 8))
axes = axes.flatten()

for i, service in enumerate(addon_services):
    filtered = df[df[service].isin(['Yes', 'No'])]
    rate = filtered.groupby(service)['Churn'].apply(
        lambda x: (x == 'Yes').mean() * 100
    )
    axes[i].bar(rate.index, rate.values)
    axes[i].set_title(service)
    axes[i].set_ylabel('Churn Rate (%)')
    axes[i].set_ylim(0, 55)

plt.suptitle('Add-on Services vs Churn Rate')
plt.tight_layout()
plt.show()
Correlation Heatmap
python
df_enc = df.copy()

yes_no_cols = [c for c in df_enc.columns
               if set(df_enc[c].dropna().unique()).issubset({'Yes', 'No'})]
for col in yes_no_cols:
    df_enc[col] = df_enc[col].map({'Yes': 1, 'No': 0})

multi_cat = [c for c in CAT_COLS if c not in yes_no_cols]
df_enc = pd.get_dummies(df_enc, columns=multi_cat, drop_first=True)

corr = df_enc.corr()
mask = np.triu(np.ones_like(corr, dtype=bool))

plt.figure(figsize=(18, 13))
sns.heatmap(corr, mask=mask, cmap='RdYlGn', center=0,
            annot=False, linewidths=0.3)
plt.title('Correlation Heatmap')
plt.tight_layout()
plt.show()

churn_corr = corr['Churn'].drop('Churn').sort_values(key=abs, ascending=False)
plt.figure(figsize=(9, 6))
plt.barh(churn_corr.index[:15], churn_corr.values[:15])
plt.axvline(0, color='black', linewidth=0.8)
plt.title('Top 15 Features Correlated with Churn')
plt.gca().invert_yaxis()
plt.tight_layout()
plt.show()
print(churn_corr.head(10))

