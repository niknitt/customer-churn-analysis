Install & Imports
python
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import warnings
warnings.filterwarnings('ignore')
pd.set_option('display.max_columns', None)
Load Data
python
df = pd.read_csv('WA_Fn-UseC_-Telco-Customer-Churn.csv')
print(df.shape)
df.head()
First Look
python
df.info()
print(df.isnull().sum())
print('Duplicates:', df.duplicated().sum())
print('TotalCharges hidden nulls:', df[df['TotalCharges'].str.strip() == ''].shape[0])
print(df['Churn'].value_counts(normalize=True).mul(100).round(1))
Clean Data
python
df['TotalCharges'] = pd.to_numeric(df['TotalCharges'], errors='coerce')
df = df.dropna(subset=['TotalCharges']).reset_index(drop=True)
df = df.drop(columns=['customerID'])
df['SeniorCitizen'] = df['SeniorCitizen'].map({0: 'No', 1: 'Yes'})

print(df.shape)  # (7032, 20)

NUM_COLS = ['tenure', 'MonthlyCharges', 'TotalCharges']
CAT_COLS = [c for c in df.columns if c not in NUM_COLS + ['Churn']]
Churn Distribution
python
fig, axes = plt.subplots(1, 2, figsize=(12, 4))
counts = df['Churn'].value_counts()
axes[0].pie(counts, labels=['No Churn', 'Churned'], autopct='%1.1f%%')
axes[0].set_title('Churn Distribution')
counts.plot(kind='bar', ax=axes[1])
axes[1].set_title('Churn Counts')
axes[1].tick_params(axis='x', rotation=0)
plt.tight_layout()
plt.show()
Numeric Distributions
python
fig, axes = plt.subplots(1, 3, figsize=(15, 4))
for ax, col in zip(axes, NUM_COLS):
    ax.hist(df[col], bins=40, edgecolor='white')
    ax.axvline(df[col].median(), color='red', linestyle='--',
               label=f'Median: {df[col].median():.0f}')
    ax.set_title(col)
    ax.legend()
plt.tight_layout()
plt.show()
Contract vs Churn
python
contract_churn = df.groupby('Contract')['Churn'].apply(
    lambda x: (x == 'Yes').mean() * 100
).sort_values(ascending=False)

fig, axes = plt.subplots(1, 2, figsize=(13, 5))
axes[0].bar(contract_churn.index, contract_churn.values, edgecolor='white')
axes[0].set_title('Churn Rate by Contract Type')
axes[0].set_ylabel('Churn Rate (%)')

pd.crosstab(df['Contract'], df['Churn'], normalize='index').mul(100).plot(
    kind='bar', stacked=True, ax=axes[1])
axes[1].set_title('Churn Proportion by Contract Type')
axes[1].tick_params(axis='x', rotation=0)
plt.tight_layout()
plt.show()
print(contract_churn)
Tenure vs Churn
python
fig, axes = plt.subplots(1, 2, figsize=(14, 5))
df.boxplot(column='tenure', by='Churn', ax=axes[0])
axes[0].set_title('Tenure by Churn')

for val, label in [('Yes', 'Churned'), ('No', 'Retained')]:
    axes[1].hist(df[df['Churn']==val]['tenure'], bins=40,
                 alpha=0.5, label=label, density=True)
axes[1].set_title('Tenure: Churned vs Retained')
axes[1].set_xlabel('Tenure (months)')
axes[1].legend()
plt.tight_layout()
plt.show()
print('Median tenure churned :', df[df['Churn']=='Yes']['tenure'].median())
print('Median tenure retained:', df[df['Churn']=='No']['tenure'].median())
Monthly Charges vs Churn
python
fig, axes = plt.subplots(1, 2, figsize=(14, 5))

for val, label in [('Yes', 'Churned'), ('No', 'Retained')]:
    axes[0].hist(df[df['Churn']==val]['MonthlyCharges'], bins=40,
                 alpha=0.5, label=label, density=True)
axes[0].set_title('Monthly Charges: Churned vs Retained')
axes[0].legend()

for val, label in [('No', 'Retained'), ('Yes', 'Churned')]:
    sub = df[df['Churn']==val]
    axes[1].scatter(sub['tenure'], sub['MonthlyCharges'], alpha=0.15, label=label, s=10)
axes[1].set_title('Tenure vs Monthly Charges')
axes[1].set_xlabel('Tenure (months)')
axes[1].set_ylabel('Monthly Charges ($)')
axes[1].legend(markerscale=4)
plt.tight_layout()
plt.show()
