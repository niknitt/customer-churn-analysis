import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from lifelines import KaplanMeierFitter

df = pd.read_csv('telco_clustered.csv')
print(df.shape)
df.head()
# Tenure ko cohort buckets me divide karo
df['tenure_cohort'] = pd.cut(
    df['tenure'],
    bins=[0, 12, 24, 36, 48, 60, 72],
    labels=['0-12', '13-24', '25-36', '37-48', '49-60', '61-72']
)

# Har cohort ka churn rate
cohort_churn = df.groupby('tenure_cohort')['Churn'].apply(
    lambda x: (x == 'Yes').mean() * 100
).reset_index()
cohort_churn.columns = ['Tenure Cohort', 'Churn Rate']

print(cohort_churn)

# Plot
plt.figure(figsize=(9, 5))
plt.bar(cohort_churn['Tenure Cohort'], cohort_churn['Churn Rate'], edgecolor='white')
plt.title('Churn Rate by Tenure Cohort')
plt.xlabel('Tenure (months)')
plt.ylabel('Churn Rate (%)')
for i, val in enumerate(cohort_churn['Churn Rate']):
    plt.text(i, val + 0.5, f'{val:.1f}%', ha='center', fontweight='bold')
plt.show()

print('Insight: 0-12 months cohort has highest churn rate')
cohort_size = df.groupby('tenure_cohort').agg(
    total    = ('Churn', 'count'),
    churned  = ('Churn', lambda x: (x == 'Yes').sum()),
    retained = ('Churn', lambda x: (x == 'No').sum()),
    churn_rate = ('Churn', lambda x: (x == 'Yes').mean() * 100)
).round(2)

print(cohort_size)

# Stacked bar
cohort_size[['retained', 'churned']].plot(kind='bar', stacked=True, figsize=(10, 5))
plt.title('Cohort Size: Retained vs Churned')
plt.xlabel('Tenure Cohort')
plt.ylabel('Number of Customers')
plt.xticks(rotation=0)
plt.legend(['Retained', 'Churned'])
plt.show()
# pip install lifelines

kmf = KaplanMeierFitter()

# Overall survival curve
kmf.fit(
    durations  = df['tenure'],
    event_observed = (df['Churn'] == 'Yes')
)

plt.figure(figsize=(10, 5))
kmf.plot_survival_function()
plt.title('Kaplan Meier Survival Curve — Overall')
plt.xlabel('Tenure (months)')
plt.ylabel('Probability of Staying')
plt.show()

# 12 mahine baad survival probability
prob_12 = kmf.survival_function_at_times([12]).values[0]
prob_24 = kmf.survival_function_at_times([24]).values[0]
prob_60 = kmf.survival_function_at_times([60]).values[0]

print(f'Probability of staying after 12 months: {prob_12*100:.1f}%')
print(f'Probability of staying after 24 months: {prob_24*100:.1f}%')
print(f'Probability of staying after 60 months: {prob_60*100:.1f}%')
plt.figure(figsize=(10, 5))

for contract in df['Contract'].unique():
    mask = df['Contract'] == contract
    kmf.fit(
        durations       = df[mask]['tenure'],
        event_observed  = (df[mask]['Churn'] == 'Yes'),
        label           = contract
    )
    kmf.plot_survival_function()

plt.title('Survival Curve by Contract Type')
plt.xlabel('Tenure (months)')
plt.ylabel('Probability of Staying')
plt.show()

print('Insight: Month-to-month customers drop off very fast in first 12 months')
# Expected remaining tenure based on contract type
expected_tenure = {
    'Month-to-month' : 18,
    'One year'       : 36,
    'Two year'       : 60
}

df['expected_tenure'] = df['Contract'].map(expected_tenure)

# CLV = monthly charges x expected tenure
df['CLV'] = df['MonthlyCharges'] * df['expected_tenure']

print(df['CLV'].describe().round(2))

# CLV distribution
plt.figure(figsize=(9, 4))
plt.hist(df['CLV'], bins=50, edgecolor='white')
plt.title('Customer Lifetime Value Distribution')
plt.xlabel('CLV ($)')
plt.ylabel('Count')
plt.show()
clv_cluster = df.groupby('Cluster').agg(
    avg_clv    = ('CLV', 'mean'),
    total_clv  = ('CLV', 'sum'),
    avg_tenure = ('tenure', 'mean'),
    churn_rate = ('Churn', lambda x: (x == 'Yes').mean() * 100)
).round(2)

print(clv_cluster)

plt.figure(figsize=(8, 4))
plt.bar(clv_cluster.index, clv_cluster['avg_clv'], edgecolor='white')
plt.title('Average CLV by Cluster')
plt.xlabel('Cluster')
plt.ylabel('Average CLV ($)')
for i, val in enumerate(clv_cluster['avg_clv']):
    plt.text(i, val + 10, f'${val:.0f}', ha='center', fontweight='bold')
plt.show()
# Churn hone wale customers ka CLV = revenue at risk
at_risk = df[df['Churn'] == 'Yes']
revenue_at_risk = at_risk['CLV'].sum()
avg_clv_churned = at_risk['CLV'].mean()

print(f'Total customers churned       : {len(at_risk):,}')
print(f'Average CLV of churned        : ${avg_clv_churned:,.2f}')
print(f'Total revenue at risk         : ${revenue_at_risk:,.2f}')

# By cluster
risk_by_cluster = at_risk.groupby('Cluster')['CLV'].agg(['sum', 'mean', 'count']).round(2)
risk_by_cluster.columns = ['Total Revenue Lost', 'Avg CLV', 'Customers Lost']
print('\nRevenue at Risk by Cluster:')
print(risk_by_cluster)
# High CLV + High churn probability = top priority for retention
df_live = df[df['Churn'] == 'No'].copy()

# Load XGBoost predictions from Phase 4
import pickle
with open('xgb_model.pkl', 'rb') as f:
    xgb = pickle.load(f)

X_live = pd.read_csv('X_train.csv')
df_live = df_live.reset_index(drop=True)

# Churn probability for retained customers
X_all = pd.concat([pd.read_csv('X_train.csv'),
                   pd.read_csv('X_test.csv')]).reset_index(drop=True)
df['churn_probability'] = xgb.predict_proba(X_all)[:, 1]

# Priority score = CLV x churn probability
df['retention_priority'] = df['CLV'] * df['churn_probability']

# Top 10 customers to target
top10 = df[df['Churn'] == 'No'].nlargest(10, 'retention_priority')[
    ['tenure', 'MonthlyCharges', 'CLV', 'churn_probability', 'retention_priority', 'Cluster']
]
print('Top 10 customers to target for retention:')
print(top10.round(2))
df.to_csv('telco_final.csv', index=False)
print('Saved telco_final.csv')
print('Phase 5 complete. Ready for Phase 6: Dashboard')
